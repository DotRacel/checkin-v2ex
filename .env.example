# Required: full browser cookie string (must include A2 and A2O).
V2EX_COOKIE=A2="..."; PB3_SESSION="..."; A2O="..."; V2EX_LANG=zhcn

# Optional: Apprise notification URLs, comma/newline separated. Empty = logs only.
#   tgram://<bot_token>/<chat_id>   bark://<key>@api.day.app   wecombot://<key>
APPRISE_URLS=

# Optional tuning.
RUN_MODE=once          # once | daemon
CHECKIN_TIME=08:30     # daemon mode local run time
HTTP_TIMEOUT=20
HTTP_RETRIES=3
